{
  "name": "mobilny-obhodchik",
  "version": "1.0.0",
  "private": true,
  "description": "Мобильный Обходчик — industrial equipment inspection system (hackathon MVP)",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "dev": "pnpm -r --parallel --filter=./packages/* dev",
    "typecheck": "pnpm -r --filter=./packages/* typecheck",
    "test": "pnpm -r --filter=./packages/* test",
    "lint": "pnpm -r --filter=./packages/* lint",
    "dev:api": "pnpm --filter @mobilny-obhodchik/api dev",
    "dev:web": "pnpm --filter @mobilny-obhodchik/web dev",
    "dev:mobile": "pnpm --filter @mobilny-obhodchik/mobile start",
    "db:migrate": "pnpm --filter @mobilny-obhodchik/api db:migrate",
    "db:seed": "pnpm --filter @mobilny-obhodchik/api db:seed",
    "db:reset": "pnpm --filter @mobilny-obhodchik/api db:reset",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "prettier": "^3.2.5"
  }
}
