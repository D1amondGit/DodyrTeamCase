# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mobilny_obhodchik?schema=public"

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# JWT secrets (override in production!)
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
MAX_UPLOAD_MB=10

# Web app
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-change-me-in-production

# Mobile app
EXPO_PUBLIC_API_URL=http://localhost:3001
