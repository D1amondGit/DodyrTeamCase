generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  WORKER
  MANAGER
  ADMIN
}

enum Shift {
  MORNING
  AFTERNOON
  NIGHT
}

enum ScheduleStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum InspectionStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  INTERRUPTED
}

enum CheckpointStatus {
  PENDING
  OK
  WARNING
  CRITICAL
  SKIPPED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DefectStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(WORKER)
  employee_id   String   @unique
  department    String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  schedules_worker  Schedule[]   @relation("WorkerSchedules")
  schedules_created Schedule[]   @relation("CreatedSchedules")
  inspections       Inspection[]
  reported_defects  Defect[]     @relation("ReportedDefects")
  resolved_defects  Defect[]     @relation("ResolvedDefects")
}

model Schedule {
  id             String         @id @default(uuid())
  worker_id      String
  route_id       String
  scheduled_date DateTime       @db.Date
  shift          Shift
  status         ScheduleStatus @default(PLANNED)
  actual_start   DateTime?
  actual_end     DateTime?
  created_by     String
  created_at     DateTime       @default(now())

  worker      User         @relation("WorkerSchedules", fields: [worker_id], references: [id])
  creator     User         @relation("CreatedSchedules", fields: [created_by], references: [id])
  route       Route        @relation(fields: [route_id], references: [id])
  inspections Inspection[]
}

model Route {
  id                         String   @id @default(uuid())
  name                       String
  description                String?
  zone                       String
  estimated_duration_minutes Int
  waypoints                  Json // JSONB - массив ID оборудования
  map_geojson                Json // JSONB - SVG/карта цеха
  is_active                  Boolean  @default(true)
  created_at                 DateTime @default(now())

  schedules   Schedule[]
  equipment   Equipment[]
  inspections Inspection[]
}

model Equipment {
  id                   String   @id @default(uuid())
  name                 String
  code                 String   @unique
  type                 String
  zone                 String
  location_description String?
  coordinates          Json // JSONB {x, y} на карте
  route_id             String
  sequence_order       Int
  checklist_template   Json // JSONB
  technical_specs      Json? // JSONB
  maintenance_docs     Json? // JSONB
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())

  route       Route        @relation(fields: [route_id], references: [id])
  checkpoints Checkpoint[]
  defects     Defect[]
}

model Inspection {
  id                    String           @id @default(uuid())
  schedule_id           String
  worker_id             String
  route_id              String
  status                InspectionStatus @default(STARTED)
  started_at            DateTime         @default(now())
  completed_at          DateTime?
  total_checkpoints     Int
  completed_checkpoints Int              @default(0)
  has_defects           Boolean          @default(false)
  notes                 String?
  offline_sync_id       String?          @unique @db.Uuid // Защита от дублей при оффлайн-синке
  created_at            DateTime         @default(now())

  schedule    Schedule     @relation(fields: [schedule_id], references: [id])
  worker      User         @relation(fields: [worker_id], references: [id])
  route       Route        @relation(fields: [route_id], references: [id])
  checkpoints Checkpoint[]
  defects     Defect[]
}

model Checkpoint {
  id               String           @id @default(uuid())
  inspection_id    String
  equipment_id     String
  sequence_order   Int
  status           CheckpointStatus @default(PENDING)
  measurements     Json? // JSONB { "temp": 85, "vib": 1.2 }
  notes            String?
  photos           Json? // JSONB
  has_defect       Boolean          @default(false)
  inspected_at     DateTime?
  duration_seconds Int?

  inspection Inspection @relation(fields: [inspection_id], references: [id])
  equipment  Equipment  @relation(fields: [equipment_id], references: [id])
  defects    Defect[]
}

model Defect {
  id               String       @id @default(uuid())
  checkpoint_id    String?
  equipment_id     String
  inspection_id    String?
  reported_by      String
  severity         Severity
  description      String
  photos           Json? // JSONB
  status           DefectStatus @default(OPEN)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  resolved_at      DateTime?
  resolved_by      String?
  resolution_notes String?

  checkpoint Checkpoint? @relation(fields: [checkpoint_id], references: [id])
  equipment  Equipment   @relation(fields: [equipment_id], references: [id])
  inspection Inspection? @relation(fields: [inspection_id], references: [id])
  reporter   User        @relation("ReportedDefects", fields: [reported_by], references: [id])
  resolver   User?       @relation("ResolvedDefects", fields: [resolved_by], references: [id])
}
