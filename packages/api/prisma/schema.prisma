// Prisma schema for "Мобильный Обходчик" — Phase 1 MVP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  WORKER
  MANAGER
  ADMIN
}

enum Shift {
  MORNING
  AFTERNOON
  NIGHT
}

enum ScheduleStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum InspectionStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  INTERRUPTED
}

enum CheckpointStatus {
  PENDING
  OK
  WARNING
  CRITICAL
  SKIPPED
}

enum DefectSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DefectStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(WORKER)
  employeeId    String   @unique
  department    String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schedulesAssigned    Schedule[]   @relation("ScheduleWorker")
  schedulesCreated     Schedule[]   @relation("ScheduleCreator")
  inspections          Inspection[]
  defectsReported      Defect[]     @relation("DefectReporter")
  defectsResolved      Defect[]     @relation("DefectResolver")
  filesUploaded        File[]
  auditEntries         AuditLog[]

  @@index([role])
  @@index([department])
}

model Route {
  id                        String    @id @default(cuid())
  name                      String
  description               String
  zone                      String
  estimatedDurationMinutes  Int
  mapGeoJSON                Json
  isActive                  Boolean   @default(true)
  createdAt                 DateTime  @default(now())

  equipment   Equipment[]
  schedules   Schedule[]
  inspections Inspection[]
}

model Equipment {
  id                    String   @id @default(cuid())
  name                  String
  code                  String   @unique
  type                  String
  zone                  String
  locationDescription   String
  coordinates           Json
  routeId               String?
  route                 Route?   @relation(fields: [routeId], references: [id])
  sequenceOrder         Int
  checklistTemplate     Json
  technicalSpecs        Json
  maintenanceDocs       Json
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())

  checkpoints Checkpoint[]
  defects     Defect[]

  @@index([routeId])
  @@index([zone])
}

model Schedule {
  id             String         @id @default(cuid())
  workerId       String
  worker         User           @relation("ScheduleWorker", fields: [workerId], references: [id])
  routeId        String
  route          Route          @relation(fields: [routeId], references: [id])
  scheduledDate  DateTime       @db.Date
  shift          Shift
  status         ScheduleStatus @default(PLANNED)
  actualStart    DateTime?
  actualEnd      DateTime?
  createdById    String
  createdBy      User           @relation("ScheduleCreator", fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())

  inspections Inspection[]

  @@index([workerId, scheduledDate])
  @@index([scheduledDate])
}

model Inspection {
  id                    String           @id @default(cuid())
  scheduleId            String
  schedule              Schedule         @relation(fields: [scheduleId], references: [id])
  workerId              String
  worker                User             @relation(fields: [workerId], references: [id])
  routeId               String
  route                 Route            @relation(fields: [routeId], references: [id])
  status                InspectionStatus @default(STARTED)
  startedAt             DateTime         @default(now())
  completedAt           DateTime?
  totalCheckpoints      Int              @default(0)
  completedCheckpoints  Int              @default(0)
  hasDefects            Boolean          @default(false)
  notes                 String?
  offlineSyncId         String?          @unique
  createdAt             DateTime         @default(now())

  checkpoints Checkpoint[]
  defects     Defect[]

  @@index([workerId])
  @@index([scheduleId])
  @@index([status])
}

model Checkpoint {
  id               String           @id @default(cuid())
  inspectionId     String
  inspection       Inspection       @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  equipmentId      String
  equipment        Equipment        @relation(fields: [equipmentId], references: [id])
  sequenceOrder    Int
  status           CheckpointStatus @default(PENDING)
  measurements     Json             @default("{}")
  notes            String?
  photos           Json             @default("[]")
  hasDefect        Boolean          @default(false)
  inspectedAt      DateTime?
  durationSeconds  Int?
  offlineSyncId    String?          @unique
  createdAt        DateTime         @default(now())

  defects Defect[]

  @@unique([inspectionId, equipmentId])
  @@index([inspectionId])
}

model Defect {
  id               String         @id @default(cuid())
  checkpointId     String?
  checkpoint       Checkpoint?    @relation(fields: [checkpointId], references: [id])
  equipmentId      String
  equipment        Equipment      @relation(fields: [equipmentId], references: [id])
  inspectionId     String?
  inspection       Inspection?    @relation(fields: [inspectionId], references: [id])
  reportedById     String
  reportedBy       User           @relation("DefectReporter", fields: [reportedById], references: [id])
  severity         DefectSeverity
  description      String?
  photos           Json           @default("[]")
  status           DefectStatus   @default(OPEN)
  resolutionNotes  String?
  resolvedById     String?
  resolvedBy       User?          @relation("DefectResolver", fields: [resolvedById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  resolvedAt       DateTime?

  @@index([status])
  @@index([equipmentId])
  @@index([severity])
}

model File {
  id            String   @id @default(cuid())
  filename      String
  originalName  String
  mimeType      String
  sizeBytes     Int
  storagePath   String
  uploadedById  String
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String
  payload     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}
